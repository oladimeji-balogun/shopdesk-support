DATABASE_URI=postgresql+psycopg2://<username>:<password>@<hostname>:5432/<database-name>

GROQ_API_KEY=gsk_......
PINECONE_API_KEY=pcsk_......
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
PINECONE_INDEX_NAME=.....
PINECONE_NAMESPACE=.....
LOG_LEVEL=DEBUG
LOG_DIR="./logs"

ROUTER_MODEL=llama-3.3-70b-versatile
RAG_MODEL=llama-3.1-8b-instant

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=12 
JWT_SECRET_KEY=.....
JWT_ALGORITHM=HS256 
